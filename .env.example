# DataLens Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env — only .env.example goes in git.

# ---------------------------------------------------------------------------
# LLM Provider (required for chat and executive summary features)
# ---------------------------------------------------------------------------

# Choose one: anthropic | openai | gemini | groq
LLM_PROVIDER=gemini

# Anthropic API Key (leave blank if using Gemini)
# Obtain at: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# OpenAI API Key (alternative — leave blank if using Anthropic)
# Obtain at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini API Key (alternative)
# Obtain at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Groq API Key (alternative)
# Obtain at: https://console.groq.com/keys
GROQ_API_KEY=

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# Path to the SQLite database file (relative to repo root)
# Default: datalens.db (created automatically on first run)
DB_PATH=datalens.db

# ---------------------------------------------------------------------------
# Ports (optional — defaults shown)
# ---------------------------------------------------------------------------

# Backend FastAPI server port
BACKEND_PORT=8000

# Frontend Vite dev server port (configured in frontend/vite.config.ts)
# FRONTEND_PORT=5173
